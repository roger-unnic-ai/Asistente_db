# ===================================
# PRODUCCIÓN - Variables de Entorno
# ===================================
# IMPORTANTE: Copia este archivo a .env.prod y cambia los valores

# Configuración de PostgreSQL
POSTGRES_DB=asistente_db_prod
POSTGRES_USER=admin_user
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO

# Notas de Seguridad:
# 1. El password debe ser fuerte: min 20 caracteres, letras, números, símbolos
# 2. NUNCA subas .env.prod a Git (ya está en .gitignore)
# 3. Genera el password con: openssl rand -base64 32
